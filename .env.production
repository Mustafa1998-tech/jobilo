NODE_ENV=production
PORT=4000

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

POSTGRES_DB=jobilo
POSTGRES_USER=jobilo
POSTGRES_PASSWORD=change-this-to-random-64-char-string

JWT_ACCESS_SECRET=change-this-to-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CORS_ORIGINS=https://your-frontend-domain.pages.dev
APP_URL=https://your-frontend-domain.pages.dev
API_URL=https://your-backend.onrender.com

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000

CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret
CLOUDINARY_FOLDER=jobilo

RESEND_API_KEY=re_your-key
RESEND_FROM=noreply@jobilo.com

SENTRY_DSN=
